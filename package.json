{
  "name": "prepsync",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "pnpm --parallel --filter web --filter api dev",
    "dev:web": "pnpm --filter web dev",
    "dev:api": "pnpm --filter api dev",
    "build": "pnpm --filter shared build && pnpm --parallel --filter web --filter api build",
    "build:web": "pnpm --filter web build",
    "build:api": "pnpm --filter shared build && pnpm --filter api build",
    "lint": "pnpm --parallel --filter web --filter api lint",
    "clean": "pnpm --parallel -r exec rm -rf node_modules dist"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  }
}